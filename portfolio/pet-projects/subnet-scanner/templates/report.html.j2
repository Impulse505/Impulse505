<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>subnet-scanner report — {{ started_at_human }}</title>
<style>
  :root { color-scheme: dark light; }
  * { box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
    margin: 0;
    padding: 24px;
    background: #0f1115;
    color: #e6e6e6;
    line-height: 1.45;
  }
  h1 { font-size: 1.6rem; margin: 0 0 4px; }
  h2 { font-size: 1.15rem; margin: 24px 0 8px; }
  .meta { color: #9aa0a6; font-size: 0.9rem; margin-bottom: 16px; }
  .stats { display: flex; gap: 24px; flex-wrap: wrap; margin-bottom: 24px; }
  .stat {
    background: #181b21;
    border: 1px solid #2a2f37;
    border-radius: 8px;
    padding: 10px 16px;
    min-width: 140px;
  }
  .stat .num { font-size: 1.6rem; font-weight: 600; display: block; }
  .stat .label { color: #9aa0a6; font-size: 0.85rem; }
  details {
    background: #14171c;
    border: 1px solid #232830;
    border-radius: 8px;
    margin-bottom: 12px;
    padding: 12px 16px;
  }
  details[open] { background: #161a21; }
  summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 1.05rem;
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }
  summary .ip { color: #f5f5f5; }
  summary .hostname { color: #80b4ff; font-weight: 500; font-size: 0.95rem; }
  summary .counts { color: #9aa0a6; font-weight: 400; font-size: 0.9rem; }
  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 12px;
    font-size: 0.92rem;
  }
  th, td { text-align: left; padding: 8px 10px; vertical-align: top; }
  thead th {
    background: #1c2027;
    color: #c6c8cc;
    font-weight: 500;
    border-bottom: 1px solid #2a2f37;
  }
  tbody tr { border-bottom: 1px solid #1f242c; }
  tbody tr:last-child { border-bottom: none; }
  .banner { color: #8b8f94; font-family: "SFMono-Regular", Menlo, Consolas, monospace; font-size: 0.82rem; }
  .severity {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .sev-CRITICAL { background: #b71c1c; color: #fff; }
  .sev-HIGH     { background: #e65100; color: #fff; }
  .sev-MEDIUM   { background: #f9a825; color: #1a1a1a; }
  .sev-LOW      { background: #1976d2; color: #fff; }
  .sev-NONE     { background: #455a64; color: #fff; }
  .cve-table {
    width: 100%;
    margin-top: 6px;
    border-collapse: collapse;
    background: #11141a;
  }
  .cve-table th { background: #1a1f27; color: #b0b3b8; font-size: 0.78rem; }
  .cve-table td { font-size: 0.85rem; }
  .cve-summary { color: #cdd1d6; }
  .cve-id a { color: #80b4ff; text-decoration: none; }
  .cve-id a:hover { text-decoration: underline; }
  .empty { color: #6c727a; font-style: italic; }
  footer {
    margin-top: 32px;
    color: #6c727a;
    font-size: 0.8rem;
    text-align: center;
  }
</style>
</head>
<body>
<h1>subnet-scanner report</h1>
<div class="meta">
  Started {{ started_at_human }} &middot; Finished {{ finished_at_human }} &middot;
  Duration {{ duration_seconds }}s
</div>

<div class="stats">
  <div class="stat"><span class="num">{{ total_hosts }}</span><span class="label">live hosts</span></div>
  <div class="stat"><span class="num">{{ total_open_ports }}</span><span class="label">open ports</span></div>
  <div class="stat"><span class="num">{{ total_cves }}</span><span class="label">CVE matches</span></div>
  <div class="stat"><span class="num">{{ severity_counts.CRITICAL + severity_counts.HIGH }}</span><span class="label">critical + high</span></div>
  <div class="stat"><span class="num">{{ firewalled }}</span><span class="label">behind firewall</span></div>
</div>

{% if hosts %}
{% for host in hosts %}
<details {% if loop.index <= 5 %}open{% endif %}>
  <summary>
    <span class="ip">{{ host.ip }}{% if host.hostname %} <span class="hostname">{{ host.hostname }}</span>{% endif %}</span>
    <span class="counts">
      {% if host.mac %}{{ host.mac }} &middot; {% endif %}
      {% if host.method and host.method != 'tcp' %}via {{ host.method }} &middot; {% endif %}
      {{ host.open_ports|length }} open port(s) &middot; {{ host.total_cves }} CVE(s)
    </span>
  </summary>

  {% if host.open_ports %}
  <table>
    <thead>
      <tr>
        <th>Port</th>
        <th>Service</th>
        <th>Version</th>
        <th>Banner</th>
        <th>CVE matches</th>
      </tr>
    </thead>
    <tbody>
    {% for row in host.open_ports %}
      <tr>
        <td>{{ row.port }}/{{ row.protocol }}</td>
        <td>{{ row.service_name }}</td>
        <td>{{ row.service_version or '—' }}</td>
        <td class="banner">{{ row.banner_short or '—' }}</td>
        <td>
          {% if row.cves %}
          <table class="cve-table">
            <thead><tr><th>CVE</th><th>CVSS</th><th>Severity</th><th>Summary</th></tr></thead>
            <tbody>
            {% for cve in row.cves %}
              <tr>
                <td class="cve-id"><a href="https://nvd.nist.gov/vuln/detail/{{ cve.cve_id }}" target="_blank" rel="noopener">{{ cve.cve_id }}</a></td>
                <td>{{ "%.1f"|format(cve.cvss_score) }}</td>
                <td><span class="severity sev-{{ cve.cvss_severity }}">{{ cve.cvss_severity }}</span></td>
                <td class="cve-summary">{{ cve.summary }}</td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
          {% else %}
          <span class="empty">no CVE matches</span>
          {% endif %}
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="empty">No open ports.</p>
  {% endif %}
</details>
{% endfor %}
{% else %}
<p class="empty">No live hosts in this scan.</p>
{% endif %}

<footer>
  Generated by subnet-scanner v0.2 &middot;
  <a href="https://github.com/Impulse505/Impulse505/tree/main/portfolio/pet-projects/subnet-scanner" style="color:#80b4ff">project page</a>
</footer>
</body>
</html>
