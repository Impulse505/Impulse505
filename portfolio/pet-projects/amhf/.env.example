# AMHF_LOG_LEVEL — DEBUG | INFO | WARNING | ERROR
AMHF_LOG_LEVEL=INFO

# AMHF_RESULTS_DIR — base directory for run-XXXX subfolders
AMHF_RESULTS_DIR=results

